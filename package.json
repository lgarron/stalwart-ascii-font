{
  "name": "stalwart-ascii-font",
  "version": "0.4.0",
  "description": "Fonts with a height (`ex`) of 4 rows and a width (`ch`) of 6 columns.",
  "author": "Lucas Garron <lucas@garron.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lgarron/stalwart-ascii-font.git"
  },
  "type": "module",
  "main": "./src/lib/index.ts",
  "exports": {
    ".": {
      "default": "./src/lib/index.ts"
    },
    "./bin/run": {
      "default": "./src/bin/main.ts"
    },
    "./data": {
      "default": "./dist/stalwart-ascii-font/stalwart-ascii-font.ts"
    },
    "./data/json": {
      "default": "./dist/stalwart-ascii-font/stalwart-ascii-font.json"
    }
  },
  "bin": {
    "stalwart": "src/bin/main.ts"
  },
  "dependencies": {
    "@optique/core": ">=0.8.2",
    "@optique/run": ">=0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@cubing/deploy": "v0.2.2",
    "@cubing/dev-config": "^0.8.3",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "barely-a-dev-server": "^0.8.1",
    "bun-dx": "^0.1.4",
    "path-class": "^0.12.2",
    "readme-cli-help": ">=0.4.10",
    "typescript": "^5.9.3"
  },
  "files": [
    "./dist/stalwart-ascii-font/",
    "./src/lib/"
  ],
  "scripts": {
    "prepublishOnly": "make prepublishOnly"
  },
  "@cubing/deploy": {
    "https://garron.net/code/stalwart/": {}
  },
  "$schema": "./node_modules/@cubing/deploy/config-schema.package.json"
}
